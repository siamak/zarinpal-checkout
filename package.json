{
  "name": "zarinpal-checkout",
  "version": "1.0.0",
  "description": "Type-safe ZarinPal checkout client for Node.js with modern tooling and backwards-compatible API methods.",
  "repository": {
    "type": "git",
    "url": "https://github.com/siamak/zarinpal-checkout"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist coverage",
    "lint": "eslint src test --ext .ts",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "zarinpal",
    "nodejs",
    "checkout",
    "typescript",
    "payment"
  ],
  "author": "siamak",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/siamak/zarinpal-checkout/issues"
  },
  "homepage": "https://github.com/siamak/zarinpal-checkout#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "axios": "^1.9.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
