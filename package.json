{
  "name": "zarinpal-checkout",
  "version": "1.0.0",
  "description": "Type-safe ZarinPal checkout client for Node.js with modern tooling and backwards-compatible API methods.",
  "repository": {
    "type": "git",
    "url": "https://github.com/siamak/zarinpal-checkout"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "examples"
  ],
  "scripts": {
    "build": "rollup -c",
    "clean": "rimraf dist coverage",
    "lint": "eslint src test",
    "test": "node --test --experimental-strip-types test/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "zarinpal",
    "nodejs",
    "checkout",
    "typescript",
    "payment"
  ],
  "author": "siamak",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/siamak/zarinpal-checkout/issues"
  },
  "homepage": "https://github.com/siamak/zarinpal-checkout/wiki",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "axios": "^1.9.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.60.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.2",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "rimraf": "^6.0.1",
    "rollup": "^4.40.0",
    "rollup-plugin-dts": "^6.2.1",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.4.1"
}
